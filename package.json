{
	"name": "provinyl-backend",
	"version": "1.0.0",
	"description": "ProVinyl backend API",
	"main": "dist/server.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"build": "tsc -p tsconfig.build.json && rm -rf dist/assets && cp -r src/assets dist/assets",
		"start": "node dist/server.js",
		"lint": "eslint src/**/*.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"run:db:silent": "mongod --dbpath ~/data/db >/dev/null 2>&1 &",
		"run:db:log": "mongod --dbpath ~/data/db --logpath ~/data/db/mongo.log &",
		"run:db:console": "mongod --dbpath ~/data/db",
		"kill:db": "pkill mongod"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"packageManager": "pnpm@11.1.3",
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1065.0",
		"@aws-sdk/s3-request-presigner": "^3.1065.0",
		"bcryptjs": "^3.0.3",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"disconnect": "^1.2.2",
		"dotenv": "^17.4.0",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.2",
		"express-validator": "^7.3.2",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.4.1",
		"pdfkit": "^0.19.1",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcryptjs": "^3.0.0",
		"@types/cookie-parser": "^1.4.9",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.5.2",
		"@types/supertest": "^6.0.3",
		"@types/uuid": "^11.0.0",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"eslint": "^10.2.0",
		"pino-pretty": "^13.1.3",
		"supertest": "^7.1.4",
		"ts-node-dev": "^2.0.0",
		"typescript": "^6.0.2",
		"vitest": "^3.2.4"
	}
}
